{
  "name": "@l1ryx/audio-pipeline-auditor-unity",
  "version": "0.1.0",
  "description": "A CLI for auditing Unity audio pipelines and generating static HTML reports.",
  "type": "module",
  "bin": {
    "audio-audit": "./dist/cli.js"
  },
  "files": [
    "assets",
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:demo": "node dist/demo/build-demo-report.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "npm run build && npm run build:demo && vite demo-site --host 127.0.0.1",
    "dev:cli": "tsx src/cli.ts",
    "dev:report": "vite demo-site --host 127.0.0.1",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "unity",
    "unity3d",
    "audio",
    "cli",
    "audit",
    "gamedev",
    "wwise",
    "fmod"
  ],
  "author": "l1ryx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l1ryx/audio-pipeline-auditor.git"
  },
  "bugs": {
    "url": "https://github.com/l1ryx/audio-pipeline-auditor/issues"
  },
  "homepage": "https://github.com/l1ryx/audio-pipeline-auditor#readme",
  "dependencies": {
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "music-metadata": "^11.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  }
}
